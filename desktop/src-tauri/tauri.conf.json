{
  "productName": "Agent Sentinel",
  "version": "0.1.0",
  "identifier": "com.agent-sentinel.desktop",
  "build": {
    "beforeDevCommand": "cd ../.. && bun run dev-web",
    "beforeBuildCommand": "cd ../.. && bun scripts/gen-icons.ts && bun run build",
    "devUrl": "http://localhost:5188/widget.html",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Sentinel",
        "width": 340,
        "height": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "url": "widget.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
