{
  "name": "agent-sentinel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot server/index.ts",
    "dev-web": "vite --config web/vite.config.ts",
    "dev-desktop": "cd desktop/src-tauri && cargo tauri dev",
    "build": "vite build --config web/vite.config.ts",
    "gen-icons": "bun scripts/gen-icons.ts",
    "build-desktop": "bun scripts/gen-icons.ts && bun run build && cd desktop/src-tauri && cargo tauri build",
    "start": "vite build --config web/vite.config.ts && bun run server/index.ts",
    "serve": "bun run server/index.ts",
    "test": "bun test server"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/bun": "^1.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vue": "^3.5.0"
  }
}
